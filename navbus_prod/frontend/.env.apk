# ─────────────────────────────────────────────────────────────
# APK BUILD ENVIRONMENT — fill in YOUR backend URL before building
# ─────────────────────────────────────────────────────────────

# Your deployed backend URL (from Render / Railway / VPS)
# Example: VITE_BACKEND_URL=https://navbus-api.onrender.com
VITE_BACKEND_URL=https://YOUR_BACKEND_URL_HERE.onrender.com

# Your Google Maps API key (optional — map shows placeholder without it)
VITE_GOOGLE_MAPS_KEY=YOUR_GOOGLE_MAPS_KEY_HERE
