{
  "appId": "com.navbus.app",
  "appName": "NavBus",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "cleartext": true,
    "allowNavigation": [
      "*.onrender.com",
      "*.railway.app",
      "maps.googleapis.com",
      "nominatim.openstreetmap.org",
      "*.openstreetmap.org"
    ]
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2500,
      "backgroundColor": "#15a8cd",
      "showSpinner": false,
      "androidSplashResourceName": "splash",
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "#15a8cd"
    },
    "Geolocation": {
      "permissions": ["location"]
    }
  },
  "android": {
    "buildOptions": {
      "releaseType": "APK"
    }
  }
}
